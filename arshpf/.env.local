
# APP_URL: The URL where this app is hosted.
# Used for self-referential links and API endpoints.
# Example: https://your-domain.com
APP_URL="https://your-domain.com"

# Public site URL used for SEO metadata (canonical URLs, sitemaps, Open Graph)
# 👉 Replace with your actual domain before deploying
# Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Optional: If your PHP API is hosted on a different domain than the frontend,
# set this to that domain. Leave empty for same-origin /api on shared hosting.
# Example: https://api.your-domain.com
# Leave empty for Hostinger shared hosting (recommended default)
NEXT_PUBLIC_API_BASE_URL=""
